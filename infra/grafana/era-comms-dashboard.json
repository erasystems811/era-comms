{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "title": "ERA Comms",
  "uid": "era-comms-main",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active Sessions",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "era_active_sessions", "legendFormat": "Sessions" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2, "type": "stat", "title": "Messages Queued / min",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(era_messages_queued_total[1m])) * 60", "legendFormat": "msg/min" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "stat", "title": "Inbound Messages / min",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(era_messages_inbound_total[1m])) * 60", "legendFormat": "msg/min" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4, "type": "stat", "title": "Webhook Delivery Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(rate(era_webhook_deliveries_total{status='delivered'}[5m])) / sum(rate(era_webhook_deliveries_total[5m]))",
        "legendFormat": "success %"
      }],
      "options": {
        "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 0.9 },
          { "color": "green", "value": 0.98 }
        ]}
      },
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 5, "type": "stat", "title": "Session Bans (total)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "era_session_bans_total", "legendFormat": "bans" }],
      "options": {
        "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 3 }
        ]}
      }
    },
    {
      "id": 6, "type": "stat", "title": "Plan Rejections / min",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(era_messages_plan_rejected_total[1m])) * 60", "legendFormat": "rejected/min" }],
      "options": {
        "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 10 }
        ]}
      }
    },
    {
      "id": 10, "type": "timeseries", "title": "Message Throughput",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(era_messages_queued_total[1m])) * 60", "legendFormat": "outbound queued/min" },
        { "expr": "sum(rate(era_messages_inbound_total[1m])) * 60", "legendFormat": "inbound/min" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Queue Depths",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "era_queue_depth{queue='inbound'}", "legendFormat": "inbound" },
        { "expr": "era_queue_depth{queue='webhooks'}", "legendFormat": "webhooks" },
        { "expr": "era_queue_depth{queue='ai'}", "legendFormat": "ai" },
        { "expr": "era_queue_depth{queue='analytics'}", "legendFormat": "analytics" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 20, "type": "timeseries", "title": "AI Response Duration (p50 / p95 / p99)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(era_ai_response_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(era_ai_response_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(era_ai_response_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 21, "type": "timeseries", "title": "Webhook Deliveries by Status",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(era_webhook_deliveries_total{status='delivered'}[1m])) * 60", "legendFormat": "delivered/min" },
        { "expr": "sum(rate(era_webhook_deliveries_total{status='failed'}[1m])) * 60", "legendFormat": "failed/min" },
        { "expr": "sum(rate(era_webhook_deliveries_total{status='dead_lettered'}[1m])) * 60", "legendFormat": "dead-lettered/min" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 30, "type": "timeseries", "title": "Node.js Heap Used",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "era_nodejs_nodejs_heap_size_used_bytes", "legendFormat": "heap used" },
        { "expr": "era_nodejs_nodejs_heap_size_total_bytes", "legendFormat": "heap total" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 31, "type": "timeseries", "title": "Event Loop Lag",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "era_nodejs_nodejs_eventloop_lag_mean_seconds", "legendFormat": "mean lag" },
        { "expr": "era_nodejs_nodejs_eventloop_lag_p99_seconds", "legendFormat": "p99 lag" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
