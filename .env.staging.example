# ── ERA COMMS STAGING ENVIRONMENT ─────────────────────────────
# Copy to .env.staging and fill in real values.
# Never commit the filled-in file.

NODE_ENV=staging
PORT=3000
HOST=0.0.0.0

# ── DATABASE ───────────────────────────────────────────────────
# POSTGRES_PASSWORD is used by both the postgres container and the app's DATABASE_URL
# (the compose overrides DATABASE_URL automatically using this value)
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_MAX_CONNECTIONS=20

# ── REDIS ──────────────────────────────────────────────────────
# REDIS_PASSWORD is used by both the redis container and the app's REDIS_URL
REDIS_PASSWORD=CHANGE_ME

# ── GRAFANA ────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME

# ── AI PROVIDERS (ERA Systems infrastructure keys) ─────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── SESSION CREDENTIAL ENCRYPTION ─────────────────────────────
# 64 hex characters = 32 bytes AES-256-GCM key
# Generate: openssl rand -hex 32
SESSION_CREDENTIALS_KEY=GENERATE_WITH_OPENSSL

# ── OPERATOR ADMIN ─────────────────────────────────────────────
# Generate: openssl rand -base64 32
OPERATOR_SECRET=GENERATE_WITH_OPENSSL

# ── MONITORING ─────────────────────────────────────────────────
ALERT_WHATSAPP_NUMBER=+2348000000000

# ── VOICE ──────────────────────────────────────────────────────
FREESWITCH_HOST=freeswitch
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

TTS_SERVICE_URL=http://coqui-tts:5002
VOICE_AUDIO_DIR=/tmp/era-voice

# Optional — uses OpenAI Whisper if not set
# DEEPGRAM_API_KEY=
