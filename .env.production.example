# ============================================================
# ERA COMMS — PRODUCTION ENVIRONMENT
# Copy to .env.production and fill in every value.
# Never commit .env.production to version control.
# ============================================================

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── SECRETS (generated by docker-compose.prod.yml via shell) ──
# These two are set in the shell / CI — not here.
# POSTGRES_PASSWORD=  (set in shell: export POSTGRES_PASSWORD=$(openssl rand -hex 24))
# REDIS_PASSWORD=     (set in shell: export REDIS_PASSWORD=$(openssl rand -hex 24))

# ── AI PROVIDERS ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── SECURITY ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_CREDENTIALS_KEY=

# Operator REST API secret (ERA Hub uses this to call /v1/admin/*)
# Generate with: openssl rand -hex 32
OPERATOR_SECRET=

# Shared secret for ERA Connect agents
CONNECT_SHARED_SECRET=era-connect-telemetry-v1

# ── MONITORING ────────────────────────────────────────────────
# Your own WhatsApp number — receives operator alerts
ALERT_WHATSAPP_NUMBER=+2348000000000

# UUID from the seed migration (check your DB: SELECT id FROM clients LIMIT 1)
OPERATOR_INTERNAL_CLIENT_ID=c0ffee00-0000-4000-a000-000000000001

# ── EMAIL — TRANSACTIONAL (OTPs, system emails) ───────────────
# Option A: Resend (easier, free tier covers OTPs)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Option B: Route OTPs through Postal instead (set RESEND_API_KEY blank)
# ERA Comms falls back to Postal SMTP when Resend key is absent.

# ── EMAIL — POSTAL (campaign / bulk sending engine) ───────────
# Set these after Postal is running (docker-compose.postal.yml)
PORTAL_URL=https://hub.yourdomain.com
POSTAL_SERVER_URL=https://postal.yourdomain.com
POSTAL_API_KEY=
POSTAL_RATE_LIMIT=50

# ── WHATSAPP PROXY (leave blank on a real VPS — not needed) ───
# Only needed if running on Railway or another blocked datacenter.
# Format: socks5://user:password@host:port
WHATSAPP_PROXY_URL=

# ── VOICE (optional — fill in when ready) ─────────────────────
SIP_TRUNK_HOST=
SIP_TRUNK_USERNAME=
SIP_TRUNK_PASSWORD=
SIP_TRUNK_FROM_NUMBER=
FREESWITCH_HOST=localhost
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
TTS_SERVICE_URL=http://localhost:5002
DEEPGRAM_API_KEY=
