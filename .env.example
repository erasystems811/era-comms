# ============================================================
# ERA COMMS — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in values before starting.
# Never commit .env to version control.
# ============================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL (standard — no TimescaleDB required)
DATABASE_URL=postgresql://era_app:password@localhost:5432/era_comms
DATABASE_MAX_CONNECTIONS=20

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI PROVIDERS ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── SECURITY ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_CREDENTIALS_KEY=

# Required — protects all /v1/admin/* routes (era-hub uses this)
# Generate with: openssl rand -base64 32
OPERATOR_SECRET=

# ── EMAIL — SYSTEM EMAILS ─────────────────────────────────────
# Used for OTP codes, portal access emails, API key emails.
# Any Gmail / Google Workspace account works.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-here
EMAIL_FROM=ERA Systems <noreply@yourdomain.com>

# ── EMAIL — BULK CAMPAIGNS ────────────────────────────────────
# Postal is your self-hosted email server (like your own Resend).
# When ready, deploy Postal on a small VPS and fill these in.
# Leave blank to skip campaign sending until Postal is set up.
POSTAL_SERVER_URL=https://postal.yourdomain.com
POSTAL_API_KEY=
POSTAL_RATE_LIMIT=50

# ── PORTAL URL ────────────────────────────────────────────────
# The public URL of era-hub — used in welcome emails sent to clients.
PORTAL_URL=https://your-era-hub-url.railway.app

# ── MONITORING ────────────────────────────────────────────────
# Your WhatsApp number — receives operator alerts (banned sessions, etc.)
ALERT_WHATSAPP_NUMBER=+234XXXXXXXXXX

# UUID of the ERA Systems internal client (set after first migration)
OPERATOR_INTERNAL_CLIENT_ID=

# ── ERA CONNECT ───────────────────────────────────────────────
# Shared secret baked into ERAConnect.exe
CONNECT_SHARED_SECRET=era-connect-telemetry-v1

# ── VOICE (optional — leave blank if not using voice) ─────────
SIP_TRUNK_HOST=
SIP_TRUNK_USERNAME=
SIP_TRUNK_PASSWORD=
SIP_TRUNK_FROM_NUMBER=
FREESWITCH_HOST=localhost
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
TTS_SERVICE_URL=http://localhost:5002
DEEPGRAM_API_KEY=
