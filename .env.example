# ============================================================
# ERA COMMS — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in values before starting the server.
# Never commit .env to version control.
# ============================================================

# Runtime environment
NODE_ENV=development

# API Server
PORT=3000
HOST=0.0.0.0

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL with TimescaleDB
DATABASE_URL=postgresql://era_app:password@localhost:5432/era_comms
DATABASE_MAX_CONNECTIONS=20

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI PROVIDERS ──────────────────────────────────────────────
# ERA Comms infrastructure keys — never exposed to clients
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── SECURITY ──────────────────────────────────────────────────
# AES-256-GCM key for session credential encryption
# Must be exactly 64 hex characters (32 bytes)
# Generate with: openssl rand -hex 32
SESSION_CREDENTIALS_KEY=

# ── MONITORING ────────────────────────────────────────────────
# E.164 number that receives operator alerts via WhatsApp
ALERT_WHATSAPP_NUMBER=+2348000000000

# UUID of the ERA Systems internal client record (created on first migrate)
OPERATOR_INTERNAL_CLIENT_ID=

# ── VOICE ─────────────────────────────────────────────────────
# SIP trunk credentials (PSTN last-mile only)
SIP_TRUNK_HOST=
SIP_TRUNK_USERNAME=
SIP_TRUNK_PASSWORD=
SIP_TRUNK_FROM_NUMBER=

# FreeSWITCH Event Socket Library
FREESWITCH_HOST=localhost
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# Coqui XTTS v2 service (self-hosted)
TTS_SERVICE_URL=http://localhost:5002

# Deepgram STT
DEEPGRAM_API_KEY=
